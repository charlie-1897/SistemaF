{
  "ConnectionStrings": {
    "SistemaF": "Server=(localdb)\\mssqllocaldb;Database=SistemaF_Dev;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/sistemaf-dev-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
