<UserControl x:Class="SistemaF.UI.WPF.Views.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Border Style="{StaticResource CardStyle}"
            Margin="24" VerticalAlignment="Center" HorizontalAlignment="Center"
            MaxWidth="480">
        <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="🚧" FontSize="52" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Sezione}"
                       Style="{StaticResource TitleMediumStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,8"/>
            <TextBlock Text="{Binding Messaggio}"
                       Style="{StaticResource BodyStyle}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>
    </Border>
</UserControl>
