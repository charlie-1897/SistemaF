<Window x:Class="SistemaF.UI.WPF.Views.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SistemaF.UI.WPF.ViewModels.Shell"
        xmlns:views="clr-namespace:SistemaF.UI.WPF.Views"
        xmlns:prodotti="clr-namespace:SistemaF.UI.WPF.Views.Prodotti"
        xmlns:vmprod="clr-namespace:SistemaF.UI.WPF.ViewModels.Prodotti"
        Title="SistemaF — Gestionale Farmacia"
        Height="760" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <!-- DataTemplates inline: collegano ViewModel → View -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vmprod:RicercaProdottoViewModel}">
            <prodotti:RicercaProdottoView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
            <views:PlaceholderView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             SIDEBAR — navigazione principale
        ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBluBrush}">
            <DockPanel>

                <!-- Logo farmacia -->
                <Border DockPanel.Dock="Top"
                        Padding="20,24,20,20"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="✚ SistemaF"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="White"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Text="{Binding NomeFarmacia}"
                                   FontSize="11"
                                   Foreground="#88AABDD0"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Footer versione -->
                <Border DockPanel.Dock="Bottom"
                        Padding="20,12"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="0,1,0,0">
                    <TextBlock Text="{Binding VersioneApp}"
                               FontSize="10"
                               Foreground="#44AABDD0"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Menu voci -->
                <StackPanel Margin="0,8">

                    <TextBlock Text="PRINCIPALE" FontSize="9"
                               Foreground="#44AABDD0"
                               FontWeight="SemiBold"
                               Margin="24,12,0,6"
                               FontFamily="Segoe UI"/>

                    <Button Content="🔍  Ricerca Prodotto"
                            Style="{Binding PaginaAttivaId,
                                Converter={StaticResource NavStyleConverter},
                                ConverterParameter=Ricerca}"
                            Command="{Binding NavigaARicercaCommand}"
                            HorizontalContentAlignment="Left"/>

                    <Button Content="🛒  Ordini"
                            Style="{Binding PaginaAttivaId,
                                Converter={StaticResource NavStyleConverter},
                                ConverterParameter=Ordini}"
                            Command="{Binding NavigaAOrdiniCommand}"
                            HorizontalContentAlignment="Left"/>

                    <Button Content="📦  Magazzino"
                            Style="{Binding PaginaAttivaId,
                                Converter={StaticResource NavStyleConverter},
                                ConverterParameter=Magazzino}"
                            Command="{Binding NavigaAMagazzinoCommand}"
                            HorizontalContentAlignment="Left"/>

                    <Button Content="🧾  Vendita"
                            Style="{Binding PaginaAttivaId,
                                Converter={StaticResource NavStyleConverter},
                                ConverterParameter=Vendita}"
                            Command="{Binding NavigaAVenditaCommand}"
                            HorizontalContentAlignment="Left"/>

                    <TextBlock Text="STRUMENTI" FontSize="9"
                               Foreground="#44AABDD0"
                               FontWeight="SemiBold"
                               Margin="24,16,0,6"
                               FontFamily="Segoe UI"/>

                    <Button Content="📊  Report"
                            Style="{Binding PaginaAttivaId,
                                Converter={StaticResource NavStyleConverter},
                                ConverterParameter=Report}"
                            Command="{Binding NavigaAReportsCommand}"
                            HorizontalContentAlignment="Left"/>

                    <Button Content="⚙  Impostazioni"
                            Style="{Binding PaginaAttivaId,
                                Converter={StaticResource NavStyleConverter},
                                ConverterParameter=Impostazioni}"
                            Command="{Binding NavigaAImpostazioniCommand}"
                            HorizontalContentAlignment="Left"/>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             AREA PRINCIPALE — header + contenuto pagina
        ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header top bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <TextBlock Text="{Binding TitoloPagina}"
                               Style="{StaticResource TitleMediumStyle}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DataOraOggi}"
                               Style="{StaticResource CaptionStyle}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Area contenuto (ContentControl mostra la pagina corrente) -->
            <ContentControl Grid.Row="1"
                            Content="{Binding PaginaCorrente}"
                            Margin="0"/>
        </Grid>
    </Grid>
</Window>
