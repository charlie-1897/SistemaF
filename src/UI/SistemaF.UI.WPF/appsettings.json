{
  "ConnectionStrings": {
    "SistemaF": "Server=(localdb)\\mssqllocaldb;Database=SistemaF;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Federfarma": {
    "DpcEndpointUrl": "https://webdpc.federfarma.lombardia.it/DpcServices/FurService.svc/base",
    "DpcSoapAction": "https://webdpc.federfarma.lombardia.it/DpcServices/FurService/IFurService/GetFUR",
    "WebCareEndpointBase": "https://webcare.federfarma.lombardia.it/{nomeAsl}/Service.svc",
    "WebCareSoapAction": "http://tempuri.org/IService/GetCompetenza",
    "TimeoutSecondi": 100
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/sistemaf-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
